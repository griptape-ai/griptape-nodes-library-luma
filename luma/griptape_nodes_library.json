{
    "name": "Luma Labs Library",
    "library_schema_version": "0.1.0",
    "settings": [
        {
            "description": "API keys required by nodes in this library",
            "category": "app_events.on_app_initialization_complete",
            "contents": {
                "secrets_to_register": [
                    "LUMA_AGENTS_API_KEY"
                ]
            }
        }
    ],
    "metadata": {
        "author": "Griptape",
        "description": "Griptape Nodes for the Luma Agents API - Image and Video Generation",
        "library_version": "0.2.0",
        "engine_version": "0.75.0",
        "tags": [
            "Griptape",
            "AI",
            "Luma Labs",
            "Luma Agents",
            "Image Generation",
            "Video Generation",
            "Text-to-Image",
            "Text-to-Video"
        ],
        "dependencies": {
            "pip_dependencies": [
                "luma-agents"
            ]
        }
    },
    "categories": [
        {
            "image/luma": {
                "color": "border-purple-500",
                "title": "Image/Luma",
                "description": "Luma Labs image generation nodes",
                "icon": "Image"
            }
        },
        {
            "video/luma": {
                "color": "border-pink-500",
                "title": "Video/Luma",
                "description": "Luma Labs video generation nodes",
                "icon": "Video"
            }
        }
    ],
    "nodes": [
        {
            "class_name": "LumaImageGeneration",
            "file_path": "image_generation.py",
            "metadata": {
                "category": "image/luma",
                "description": "Generate high-quality images using Luma Agents models with support for text-to-image, image references, and image editing",
                "display_name": "Luma Image Generation"
            }
        },
        {
            "class_name": "LumaVideoGeneration",
            "file_path": "video_generation.py",
            "metadata": {
                "category": "video/luma",
                "description": "Generate videos using Luma Agents Ray models with text-to-video and image-to-video capabilities",
                "display_name": "Luma Video Generation"
            }
        },
        {
            "class_name": "LumaVideoReframe",
            "file_path": "video_reframe.py",
            "metadata": {
                "category": "video/luma",
                "description": "Reframe videos to different aspect ratios using Luma Agents Ray models with optional content steering",
                "display_name": "Luma Video Reframe"
            }
        },
        {
            "class_name": "LumaVideoModify",
            "file_path": "video_modify.py",
            "metadata": {
                "category": "video/luma",
                "description": "Modify videos with style transfer and prompt-based editing using Luma Agents Ray models. Supports Adhere (subtle), Flex (balanced), and Reimagine (dramatic) modes",
                "display_name": "Luma Video Modify"
            }
        }
    ]
}
